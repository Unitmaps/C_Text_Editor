{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: Clang build active file",
            "command": "clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${fileDirname}\\*.c",
                "-o",                
                "${fileDirname}\\${fileBasenameNoExtension}.exe",
                "-fmessage-length=0",
                "-ferror-limit=3"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}